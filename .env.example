# Telegram-бот: токен от @BotFather
BOT_TOKEN=12345:AAA-замените-на-токен-от-BotFather

# URL форума (по умолчанию основной BR)
FORUM_URL=https://forum.blackrussia.online

# Путь к SQLite-базе относительно корня проекта
DB_PATH=bot_database.db

# ID раздела форума по умолчанию (используется как fallback). Можно оставить 0.
DEFAULT_FORUM_SECTION_ID=0

# Telegram ID администраторов через запятую.
# Только эти пользователи могут логиниться, синхронизировать форум и
# управлять аккаунтами. Их пул используется для подачи жалоб обычными юзерами.
# Если оставить пустым — все становятся админами (только для отладки!).
ADMIN_IDS=123456789

# User-Agent для прохождения DDoS-Guard. ВАЖНО: должен совпадать с тем
# браузером, из которого вы экспортировали cookies.json (если используете
# ручную загрузку кук). При логине по паролю можно оставить любой свежий
# UA Chrome или Firefox.
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
